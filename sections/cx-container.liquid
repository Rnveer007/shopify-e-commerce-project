<section class="cx-main-container" style="background: {{ section.settings.bg }}; margin-bottom: {{ section.settings.mb }};">
  <div style="max-width: {% if section.settings.fw %}100%{% else %}1440px{% endif %}; margin: 0 auto; padding: 0 15px;">
    {% content_for 'blocks' %}
  </div>
</section>

{% schema %}
{
  "name": "CX Container",
  "settings": [
    { "type": "checkbox", "id": "fw", "label": "Full Width", "default": false },
    { "type": "color", "id": "bg", "label": "Background", "default": "transparent" },
    { "type": "text", "id": "mb", "label": "Margin Bottom", "default": "40px" }
  ],
  "blocks": [
    { "type": "cx-rich-text" },
    { "type": "cx-media-card" }
  ],
  "presets": [{ "name": "CX Container" }]
}
{% endschema %}