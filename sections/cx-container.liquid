{%- comment -%}
  CX Container - Updated with Fixed Padding & Step-based Margins
{%- endcomment -%}

<section id="cx-section-{{ section.id }}" 
  class="cx-main-parent 
    {% if section.settings.remove_padding_desktop %} remove-pd-desktop {% endif %} 
    {% if section.settings.remove_padding_mobile %} remove-pd-mobile {% endif %}" 
  style="
    --mb: {{ section.settings.margin_bottom }};
    --bg-color: {{ section.settings.bg_color }};
  ">
  
  <div class="cx-wrapper {% if section.settings.no_gutter %}cx-width-expanded{% else %}cx-width-default{% endif %}">
    <div class="cx-inner-content">
      {% content_for 'blocks' %}
    </div>
  </div>

</section>

<style>
  .cx-main-parent {
    background-color: var(--bg-color);
    margin-bottom: var(--mb);
    width: 100%;
    overflow: hidden;
  }
  
  .cx-wrapper {
    margin: 0 auto;
    transition: max-width 0.4s ease-in-out;
  }

  /* Default Padding 15px all sides */
  .cx-inner-content {
    padding: 15px;
  }

  /* Logic to remove padding */
  @media (min-width: 769px) {
    .remove-pd-desktop .cx-inner-content {
      padding: 0;
    }
  }

  @media (max-width: 768px) {
    .remove-pd-mobile .cx-inner-content {
      padding: 0;
    }
  }

  .cx-width-default { max-width: 1440px; }
  .cx-width-expanded { max-width: 1920px; }
</style>

{% schema %}
{
  "name": "CX Container",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Container Width"
    },
    {
      "type": "checkbox",
      "id": "no_gutter",
      "label": "No Gutter (1920px)",
      "default": false
    },
    {
      "type": "header",
      "content": "Padding Controls (Default 15px)"
    },
    {
      "type": "checkbox",
      "id": "remove_padding_desktop",
      "label": "Remove Padding - Desktop",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "remove_padding_mobile",
      "label": "Remove Padding - Mobile",
      "default": false
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "select",
      "id": "margin_bottom",
      "label": "Margin Bottom",
      "options": [
        { "value": "0px", "label": "None" },
        { "value": "20px", "label": "Small" },
        { "value": "40px", "label": "Medium" },
        { "value": "60px", "label": "Large" },
        { "value": "80px", "label": "Larger" }
      ],
      "default": "40px"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "transparent"
    }
  ],
  "blocks": [
    { "type": "@theme" },
    { "type": "@app" }
  ],
  "presets": [
    { "name": "CX Container" }
  ]
}
{% endschema %}