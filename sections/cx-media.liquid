{%- comment -%}
  CX Media Section - Clean Static Version (No Hover)
{%- endcomment -%}

<div class="cx-media cx-media-{{ section.id }}" 
     style="margin-bottom: {{ section.settings.mb }};">
  
  <div class="cx-media-container">
    {% if section.settings.image_desktop != blank %}
      <picture>
        {% if section.settings.image_mobile != blank %}
          <source media="(max-width: 767px)" srcset="{{ section.settings.image_mobile | image_url: width: 800 }}">
        {% endif %}
        <img 
          src="{{ section.settings.image_desktop | image_url: width: 2000 }}" 
          alt="{{ section.settings.image_desktop.alt | escape }}"
          loading="lazy"
          class="cx-media-img"
        >
      </picture>
    {% else %}
      {{ 'lifestyle-1' | placeholder_svg_tag: 'cx-placeholder' }}
    {% endif %}
  </div>

</div>

<style>
  .cx-media-{{ section.id }} {
    width: 100%;
    overflow: hidden;
    padding: 0 15px;
  }

  .cx-media-{{ section.id }} .cx-media-container {
    border-radius: {{ section.settings.radius }}px;
    overflow: hidden;
    line-height: 0;
  }

  .cx-media-img {
    width: 100%;
    height: auto;
    object-fit: cover;
    display: block;
    /* Hover transitions removed */
  }

  .cx-placeholder {
    width: 100%;
    height: 400px;
    background: #f3f3f3;
  }
</style>

{% schema %}
{
  "name": "CX Media",
  "tag": "section",
  "settings": [
    { "type": "header", "content": "Desktop Settings" },
    { "type": "image_picker", "id": "image_desktop", "label": "Image (Desktop)" },
    { "type": "header", "content": "Mobile Settings" },
    { "type": "image_picker", "id": "image_mobile", "label": "Image (Mobile)" },
    { "type": "header", "content": "Layout & Style" },
    { "type": "range", "id": "radius", "min": 0, "max": 40, "step": 2, "unit": "px", "label": "Corner Roundness", "default": 0 },
    {
      "type": "select",
      "id": "mb",
      "label": "Margin Bottom",
      "options": [
        { "value": "0px", "label": "None" },
        { "value": "20px", "label": "Small" },
        { "value": "40px", "label": "Medium" },
        { "value": "60px", "label": "Large" }
      ],
      "default": "40px"
    }
  ],
  "presets": [{ "name": "CX Media" }]
}
{% endschema %}