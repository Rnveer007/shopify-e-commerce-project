<div class="cx-rt-wrapper cx-rt-{{ block.id }}" style="
  {% if block.settings.bg_color.alpha != 0 %}
    --bg-color: {{ block.settings.bg_color | color_modify: 'alpha', block.settings.bg_opacity }};
  {% else %}
    --bg-color: transparent;
  {% endif %}
  --pt-desktop: {{ block.settings.main_pt_desktop }}px;
  --pb-desktop: {{ block.settings.main_pb_desktop }}px;
  --pl-desktop: {{ block.settings.main_pl_desktop }}px;
  --pr-desktop: {{ block.settings.main_pr_desktop }}px;
  --pt-mobile: {{ block.settings.main_pt_mobile }}px;
  --pb-mobile: {{ block.settings.main_pb_mobile }}px;
  --pl-mobile: {{ block.settings.main_pl_mobile }}px;
  --pr-mobile: {{ block.settings.main_pr_mobile }}px;
  --mt-desktop: {{ block.settings.main_mt_desktop }}px;
  --mb-desktop: {{ block.settings.main_mb_desktop }}px;
  --radius: {{ block.settings.main_radius }}px;
  --align: {{ block.settings.main_align }};
  --bw-main: {{ block.settings.main_bw }}px;
  --bc-main: {{ block.settings.main_bc }};
">
  <div class="cx-rt-content">
    {% if block.settings.subheading != blank %}<p class="cx-el-sub" style="--c: {{ block.settings.c_sub }}; --fs-desktop: {{ block.settings.fs_sub_desktop }}px; --fs-mobile: {{ block.settings.fs_sub_mobile }}px; --lh: {{ block.settings.lh_sub }}; --mt: {{ block.settings.mt_sub }}px; --mb: {{ block.settings.mb_sub }}px; --bg: {{ block.settings.bg_sub }}; --bw: {{ block.settings.bw_sub }}px; --bc: {{ block.settings.bc_sub }};">{{ block.settings.subheading }}</p>{% endif %}
    {% if block.settings.title != blank %}<h2 class="cx-el-h" style="--c: {{ block.settings.c_h }}; --fs-desktop: {{ block.settings.fs_h_desktop }}px; --fs-mobile: {{ block.settings.fs_h_mobile }}px; --lh: {{ block.settings.lh_h }}; --mt: {{ block.settings.mt_h }}px; --mb: {{ block.settings.mb_h }}px; --bg: {{ block.settings.bg_h }}; --bw: {{ block.settings.bw_h }}px; --bc: {{ block.settings.bc_h }};">{{ block.settings.title }}</h2>{% endif %}
    {% if block.settings.text != blank %}<div class="cx-el-p" style="--c: {{ block.settings.c_p }}; --fs-desktop: {{ block.settings.fs_p_desktop }}px; --fs-mobile: {{ block.settings.fs_p_mobile }}px; --lh: {{ block.settings.lh_p }}; --mt: {{ block.settings.mt_p }}px; --mb: {{ block.settings.mb_p }}px; --bg: {{ block.settings.bg_p }}; --bw: {{ block.settings.bw_p }}px; --bc: {{ block.settings.bc_p }};">{{ block.settings.text }}</div>{% endif %}
    {% if block.settings.btn_label != blank %}<div class="cx-btn-wrap" style="--mt: {{ block.settings.mt_btn }}px; --mb: {{ block.settings.mb_btn }}px;"><a href="{{ block.settings.btn_link }}" class="cx-el-btn" style="background: {{ block.settings.bg_btn }}; color: {{ block.settings.c_btn }}; font-size: {{ block.settings.fs_btn }}px; border: {{ block.settings.bw_btn }}px solid {{ block.settings.bc_btn }};">{{ block.settings.btn_label }}</a></div>{% endif %}
  </div>
</div>

<style>
  .cx-rt-{{ block.id }} { background-color: var(--bg-color) !important; text-align: var(--align) !important; border-radius: var(--radius) !important; border: var(--bw-main) solid var(--bc-main) !important; padding: var(--pt-desktop) var(--pr-desktop) var(--pb-desktop) var(--pl-desktop) !important; margin: var(--mt-desktop) 0 var(--mb-desktop) 0 !important; width: 100% !important; box-sizing: border-box !important; display: block !important; }
  .cx-el-sub, .cx-el-h, .cx-el-p, .cx-el-p p { display: block !important; padding: 0 !important; margin: 0 !important; }
  .cx-el-sub, .cx-el-h, .cx-el-p { margin-top: var(--mt) !important; margin-bottom: var(--mb) !important; color: var(--c) !important; background-color: var(--bg) !important; border: var(--bw) solid var(--bc) !important; font-size: var(--fs-desktop) !important; line-height: var(--lh) !important; box-sizing: border-box !important; }
  .cx-el-btn { display: inline-block !important; padding: 12px 30px !important; text-decoration: none !important; border-radius: 4px !important; font-weight: bold !important; }
  @media (max-width: 768px) { .cx-rt-{{ block.id }} { padding: var(--pt-mobile) var(--pr-mobile) var(--pb-mobile) var(--pl-mobile) !important; } }
</style>

{% schema %}
{
  "name": "CX Rich Text Pro",
  "settings": [
    { "type": "header", "content": "MAIN BOX SETTINGS" },
    { "type": "select", "id": "main_align", "label": "Text Alignment", "options": [{"value":"left","label":"Left Alignment"},{"value":"center","label":"Center Alignment"},{"value":"right","label":"Right Alignment"}], "default": "center" },
    { "type": "color", "id": "bg_color", "label": "Background Color", "default": "rgba(0,0,0,0)" },
    { "type": "range", "id": "bg_opacity", "min": 0, "max": 1, "step": 0.1, "label": "Background Opacity", "default": 0 },
    { "type": "range", "id": "main_radius", "min": 0, "max": 60, "step": 2, "unit": "px", "label": "Corner Radius", "default": 0 },
    { "type": "range", "id": "main_bw", "min": 0, "max": 10, "step": 1, "label": "Main Border Width", "default": 0 },
    { "type": "color", "id": "main_bc", "label": "Main Border Color", "default": "#000000" },
    { "type": "header", "content": "BOX PADDING - DESKTOP" },
    { "type": "range", "id": "main_pt_desktop", "min": 0, "max": 200, "step": 2, "unit": "px", "label": "Padding Top", "default": 20 },
    { "type": "range", "id": "main_pb_desktop", "min": 0, "max": 200, "step": 2, "unit": "px", "label": "Padding Bottom", "default": 20 },
    { "type": "range", "id": "main_pl_desktop", "min": 0, "max": 200, "step": 2, "unit": "px", "label": "Padding Left", "default": 20 },
    { "type": "range", "id": "main_pr_desktop", "min": 0, "max": 200, "step": 2, "unit": "px", "label": "Padding Right", "default": 20 },
    { "type": "header", "content": "BOX PADDING - MOBILE" },
    { "type": "range", "id": "main_pt_mobile", "min": 0, "max": 150, "step": 2, "unit": "px", "label": "Padding Top Mobile", "default": 15 },
    { "type": "range", "id": "main_pb_mobile", "min": 0, "max": 150, "step": 2, "unit": "px", "label": "Padding Bottom Mobile", "default": 15 },
    { "type": "range", "id": "main_pl_mobile", "min": 0, "max": 150, "step": 2, "unit": "px", "label": "Padding Left Mobile", "default": 15 },
    { "type": "range", "id": "main_pr_mobile", "min": 0, "max": 150, "step": 2, "unit": "px", "label": "Padding Right Mobile", "default": 15 },
    { "type": "header", "content": "MARGIN - DESKTOP" },
    { "type": "range", "id": "main_mt_desktop", "min": 0, "max": 100, "step": 2, "unit": "px", "label": "Margin Top Desktop", "default": 0 },
    { "type": "range", "id": "main_mb_desktop", "min": 0, "max": 100, "step": 2, "unit": "px", "label": "Margin Bottom Desktop", "default": 0 },
    { "type": "header", "content": "1. SUBHEADING" },
    { "type": "text", "id": "subheading", "label": "Text", "default": "Subheading" },
    { "type": "color", "id": "c_sub", "label": "Color", "default": "#EB1A1A" },
    { "type": "color", "id": "bg_sub", "label": "BG Color", "default": "rgba(0,0,0,0)" },
    { "type": "range", "id": "bw_sub", "min": 0, "max": 10, "step": 1, "label": "Border Width", "default": 0 },
    { "type": "color", "id": "bc_sub", "label": "Border Color", "default": "#000" },
    { "type": "number", "id": "fs_sub_desktop", "label": "Font Size Desktop", "default": 32 },
    { "type": "number", "id": "fs_sub_mobile", "label": "Font Size Mobile", "default": 12 },
    { "type": "text", "id": "lh_sub", "label": "Line Height", "default": "1.2" },
    { "type": "range", "id": "mt_sub", "min": 0, "max": 50, "label": "Margin Top", "default": 0 },
    { "type": "range", "id": "mb_sub", "min": 0, "max": 50, "label": "Margin Bottom", "default": 10 },
    { "type": "header", "content": "2. HEADING" },
    { "type": "text", "id": "title", "label": "Text", "default": "Main Heading" },
    { "type": "color", "id": "c_h", "label": "Color", "default": "#000" },
    { "type": "color", "id": "bg_h", "label": "BG Color", "default": "rgba(0,0,0,0)" },
    { "type": "range", "id": "bw_h", "min": 0, "max": 10, "step": 1, "label": "Border Width", "default": 0 },
    { "type": "color", "id": "bc_h", "label": "Border Color", "default": "#000" },
    { "type": "number", "id": "fs_h_desktop", "label": "Font Size Desktop", "default": 40 },
    { "type": "number", "id": "fs_h_mobile", "label": "Font Size Mobile", "default": 30 },
    { "type": "text", "id": "lh_h", "label": "Line Height", "default": "1.1" },
    { "type": "range", "id": "mt_h", "min": 0, "max": 50, "label": "Margin Top", "default": 0 },
    { "type": "range", "id": "mb_h", "min": 0, "max": 50, "label": "Margin Bottom", "default": 20 },
    { "type": "header", "content": "3. PARAGRAPH" },
    { "type": "richtext", "id": "text", "label": "Text", "default": "<p>Professional description for your brand.</p>" },
    { "type": "color", "id": "c_p", "label": "Color", "default": "#333" },
    { "type": "color", "id": "bg_p", "label": "BG Color", "default": "rgba(0,0,0,0)" },
    { "type": "range", "id": "bw_p", "min": 0, "max": 10, "step": 1, "label": "Border Width", "default": 0 },
    { "type": "color", "id": "bc_p", "label": "Border Color", "default": "#000" },
    { "type": "number", "id": "fs_p_desktop", "label": "Font Size Desktop", "default": 18 },
    { "type": "number", "id": "fs_p_mobile", "label": "Font Size Mobile", "default": 16 },
    { "type": "text", "id": "lh_p", "label": "Line Height", "default": "1.6" },
    { "type": "range", "id": "mt_p", "min": 0, "max": 50, "label": "Margin Top", "default": 0 },
    { "type": "range", "id": "mb_p", "min": 0, "max": 50, "label": "Margin Bottom", "default": 20 },
    { "type": "header", "content": "4. BUTTON" },
    { "type": "text", "id": "btn_label", "label": "Label", "default": "Shop Now" },
    { "type": "url", "id": "btn_link", "label": "Link" },
    { "type": "color", "id": "bg_btn", "label": "BG Color", "default": "#000" },
    { "type": "color", "id": "c_btn", "label": "Text Color", "default": "#fff" },
    { "type": "range", "id": "bw_btn", "min": 0, "max": 10, "step": 1, "label": "Border Width", "default": 0 },
    { "type": "color", "id": "bc_btn", "label": "Border Color", "default": "rgba(0,0,0,0)" },
    { "type": "number", "id": "fs_btn", "label": "Font Size", "default": 16 },
    { "type": "range", "id": "mt_btn", "min": 0, "max": 50, "label": "Margin Top", "default": 10 },
    { "type": "range", "id": "mb_btn", "min": 0, "max": 50, "label": "Margin Bottom", "default": 0 }
  ],
  "presets": [{ "name": "CX Rich Text Pro" }]
}
{% endschema %}