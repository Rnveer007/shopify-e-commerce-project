<div class="cx-rt-wrapper cx-rt-{{ block.id }}" style="
  --bg-color: {{ block.settings.bg_color | color_modify: 'alpha', block.settings.bg_opacity }};
  --pt-dt: {{ block.settings.pt_dt }}px;
  --pb-dt: {{ block.settings.pb_dt }}px;
  --pt-mb: {{ block.settings.pt_mb }}px;
  --pb-mb: {{ block.settings.pb_mb }}px;
  --mt-dt: {{ block.settings.mt_dt }}px;
  --mb-dt: {{ block.settings.mb_dt }}px;
  --mt-mb: {{ block.settings.mt_mb }}px;
  --mb-mb: {{ block.settings.mb_mb }}px;
  --radius: {{ block.settings.radius }}px;
  --align: {{ block.settings.align }};
">
  
  <div class="cx-rt-content">
    {%- comment -%} SUBHEADING {%- endcomment -%}
    {% if block.settings.subheading != blank %}
      <p class="cx-el-sub" style="--c: {{ block.settings.c_sub }}; --fs-dt: {{ block.settings.fs_sub_dt }}px; --fs-mb: {{ block.settings.fs_sub_mb }}px; --lh: {{ block.settings.lh_sub }}; --mt: {{ block.settings.mt_sub }}px; --mb: {{ block.settings.mb_sub }}px; --bg: {{ block.settings.bg_sub }};">{{ block.settings.subheading }}</p>
    {% endif %}

    {%- comment -%} HEADING {%- endcomment -%}
    {% if block.settings.title != blank %}
      <h2 class="cx-el-h" style="--c: {{ block.settings.c_h }}; --fs-dt: {{ block.settings.fs_h_dt }}px; --fs-mb: {{ block.settings.fs_h_mb }}px; --lh: {{ block.settings.lh_h }}; --mt: {{ block.settings.mt_h }}px; --mb: {{ block.settings.mb_h }}px; --bg: {{ block.settings.bg_h }};">{{ block.settings.title }}</h2>
    {% endif %}

    {%- comment -%} PARAGRAPH {%- endcomment -%}
    {% if block.settings.text != blank %}
      <div class="cx-el-p" style="--c: {{ block.settings.c_p }}; --fs-dt: {{ block.settings.fs_p_dt }}px; --fs-mb: {{ block.settings.fs_p_mb }}px; --lh: {{ block.settings.lh_p }}; --mt: {{ block.settings.mt_p }}px; --mb: {{ block.settings.mb_p }}px; --bg: {{ block.settings.bg_p }};">{{ block.settings.text }}</div>
    {% endif %}

    {%- comment -%} BUTTON {%- endcomment -%}
    {% if block.settings.btn_label != blank %}
      <div style="margin-top: {{ block.settings.mt_btn }}px; margin-bottom: {{ block.settings.mb_btn }}px;">
        <a href="{{ block.settings.btn_link }}" class="cx-el-btn" style="background: {{ block.settings.bg_btn }}; color: {{ block.settings.c_btn }}; font-size: {{ block.settings.fs_btn }}px;">{{ block.settings.btn_label }}</a>
      </div>
    {% endif %}
  </div>
</div>

<style>
  .cx-rt-{{ block.id }} {
    background-color: var(--bg-color);
    text-align: var(--align);
    border-radius: var(--radius);
    padding-top: var(--pt-dt);
    padding-bottom: var(--pb-dt);
    margin-top: var(--mt-dt);
    margin-bottom: var(--mb-dt);
    width: 100%;
    box-sizing: border-box;
    padding-left: 20px; padding-right: 20px; /* Internal safe breathing space */
  }
  .cx-el-sub, .cx-el-h, .cx-el-p {
    display: block; margin: 0; color: var(--c); background-color: var(--bg);
    margin-top: var(--mt); margin-bottom: var(--mb);
    line-height: var(--lh); font-size: var(--fs-dt);
  }
  .cx-el-btn {
    display: inline-block; padding: 12px 30px; text-decoration: none; border-radius: 4px; font-weight: bold;
  }
  @media (max-width: 768px) {
    .cx-rt-{{ block.id }} {
      padding-top: var(--pt-mb); padding-bottom: var(--pb-mb);
      margin-top: var(--mt-mb); margin-bottom: var(--mb-mb);
    }
    .cx-el-sub, .cx-el-h, .cx-el-p { font-size: var(--fs-mb); }
  }
</style>

{% schema %}
{
  "name": "CX Rich Text Pro",
  "settings": [
    { "type": "header", "content": "MAIN BOX CONTROLS" },
    { "type": "select", "id": "align", "label": "Text Align", "options": [{"value":"left","label":"Left"},{"value":"center","label":"Center"},{"value":"right","label":"Right"}], "default": "center" },
    { "type": "color", "id": "bg_color", "label": "Box Background Color", "default": "#ffffff" },
    { "type": "range", "id": "bg_opacity", "min": 0, "max": 1, "step": 0.1, "label": "Background Opacity", "default": 1.0 },
    { "type": "range", "id": "radius", "min": 0, "max": 60, "step": 2, "unit": "px", "label": "Box Roundness", "default": 0 },
    
    { "type": "header", "content": "MAIN BOX SPACING (DESKTOP)" },
    { "type": "range", "id": "pt_dt", "min": 0, "max": 120, "step": 2, "label": "Padding Top", "default": 40 },
    { "type": "range", "id": "pb_dt", "min": 0, "max": 120, "step": 2, "label": "Padding Bottom", "default": 40 },
    { "type": "range", "id": "mt_dt", "min": 0, "max": 100, "step": 2, "label": "Margin Top", "default": 0 },
    { "type": "range", "id": "mb_dt", "min": 0, "max": 100, "step": 2, "label": "Margin Bottom", "default": 0 },

    { "type": "header", "content": "MAIN BOX SPACING (MOBILE)" },
    { "type": "range", "id": "pt_mb", "min": 0, "max": 100, "step": 2, "label": "Padding Top Mobile", "default": 20 },
    { "type": "range", "id": "pb_mb", "min": 0, "max": 100, "step": 2, "label": "Padding Bottom Mobile", "default": 20 },
    { "type": "range", "id": "mt_mb", "min": 0, "max": 80, "step": 2, "label": "Margin Top Mobile", "default": 0 },
    { "type": "range", "id": "mb_mb", "min": 0, "max": 80, "step": 2, "label": "Margin Bottom Mobile", "default": 0 },

    { "type": "header", "content": "1. SUBHEADING" },
    { "type": "text", "id": "subheading", "label": "Text", "default": "Subheading" },
    { "type": "color", "id": "c_sub", "label": "Color", "default": "#666" },
    { "type": "color", "id": "bg_sub", "label": "BG Color", "default": "transparent" },
    { "type": "number", "id": "fs_sub_dt", "label": "Font Size DT", "default": 16 },
    { "type": "number", "id": "fs_sub_mb", "label": "Font Size MB", "default": 14 },
    { "type": "text", "id": "lh_sub", "label": "Line Height", "default": "1.2" },
    { "type": "range", "id": "mt_sub", "min": 0, "max": 50, "label": "Margin Top", "default": 0 },
    { "type": "range", "id": "mb_sub", "min": 0, "max": 50, "label": "Margin Bottom", "default": 10 },

    { "type": "header", "content": "2. HEADING" },
    { "type": "text", "id": "title", "label": "Text", "default": "Main Heading" },
    { "type": "color", "id": "c_h", "label": "Color", "default": "#000" },
    { "type": "color", "id": "bg_h", "label": "BG Color", "default": "transparent" },
    { "type": "number", "id": "fs_h_dt", "label": "Font Size DT", "default": 40 },
    { "type": "number", "id": "fs_h_mb", "label": "Font Size MB", "default": 30 },
    { "type": "text", "id": "lh_h", "label": "Line Height", "default": "1.1" },
    { "type": "range", "id": "mt_h", "min": 0, "max": 50, "label": "Margin Top", "default": 0 },
    { "type": "range", "id": "mb_h", "min": 0, "max": 50, "label": "Margin Bottom", "default": 20 },

    { "type": "header", "content": "3. PARAGRAPH" },
    { "type": "richtext", "id": "text", "label": "Text", "default": "<p>Professional description for your brand.</p>" },
    { "type": "color", "id": "c_p", "label": "Color", "default": "#333" },
    { "type": "color", "id": "bg_p", "label": "BG Color", "default": "transparent" },
    { "type": "number", "id": "fs_p_dt", "label": "Font Size DT", "default": 18 },
    { "type": "number", "id": "fs_p_mb", "label": "Font Size MB", "default": 16 },
    { "type": "text", "id": "lh_p", "label": "Line Height", "default": "1.6" },
    { "type": "range", "id": "mt_p", "min": 0, "max": 50, "label": "Margin Top", "default": 0 },
    { "type": "range", "id": "mb_p", "min": 0, "max": 50, "label": "Margin Bottom", "default": 20 },

    { "type": "header", "content": "4. BUTTON" },
    { "type": "text", "id": "btn_label", "label": "Label", "default": "Shop Now" },
    { "type": "url", "id": "btn_link", "label": "Link" },
    { "type": "color", "id": "bg_btn", "label": "BG Color", "default": "#000" },
    { "type": "color", "id": "c_btn", "label": "Text Color", "default": "#fff" },
    { "type": "number", "id": "fs_btn", "label": "Font Size", "default": 16 },
    { "type": "range", "id": "mt_btn", "min": 0, "max": 50, "label": "Margin Top", "default": 10 },
    { "type": "range", "id": "mb_btn", "min": 0, "max": 50, "label": "Margin Bottom", "default": 0 }
  ],
  "presets": [{ "name": "CX Rich Text Pro" }]
}
{% endschema %}