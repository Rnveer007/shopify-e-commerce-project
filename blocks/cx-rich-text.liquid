<div class="cx-rich-text cx-rt-{{ block.id }}" style="
  {% if block.settings.bg_img != blank %}
    --bg-img: url('{{ block.settings.bg_img | image_url: width: 2000 }}');
  {% else %}
    --bg-img: none;
  {% endif %}
  --overlay: {{ block.settings.overlay_color | color_modify: 'alpha', block.settings.overlay_opacity }};
  --align: {{ block.settings.text_align }};
  /* Desktop Padding */
  --pt-dt: {{ block.settings.pd_top_dt }}px;
  --pb-dt: {{ block.settings.pd_bottom_dt }}px;
  --pl-dt: {{ block.settings.pd_left_dt }}px;
  --pr-dt: {{ block.settings.pd_right_dt }}px;
  /* Mobile Padding */
  --pt-mb: {{ block.settings.pd_top_mb }}px;
  --pb-mb: {{ block.settings.pd_bottom_mb }}px;
  --pl-mb: {{ block.settings.pd_left_mb }}px;
  --pr-mb: {{ block.settings.pd_right_mb }}px;
">
  <div class="cx-rt-overlay"></div>
  <div class="cx-rt-content">
    {% if block.settings.heading != blank %}
      <h2 class="cx-rt-title" style="color: {{ block.settings.color_h }}; font-size: {{ block.settings.fs_h_dt }}px;">
        {{ block.settings.heading }}
      </h2>
    {% endif %}
    {% if block.settings.paragraph != blank %}
      <div class="cx-rt-para" style="color: {{ block.settings.color_p }};">
        {{ block.settings.paragraph }}
      </div>
    {% endif %}
  </div>
</div>

<style>
  .cx-rich-text { 
    position: relative; background-image: var(--bg-img); background-size: cover; background-position: center;
    text-align: var(--align); overflow: hidden;
    padding: var(--pt-dt) var(--pr-dt) var(--pb-dt) var(--pl-dt) !important;
  }
  .cx-rt-overlay { position: absolute; top:0; left:0; width:100%; height:100%; background: var(--overlay); z-index:1; }
  .cx-rt-content { position: relative; z-index: 2; }
  .cx-rt-title { margin: 0; line-height: 1.2; }
  .cx-rt-para { margin-top: 15px; }
  @media (max-width: 768px) {
    .cx-rich-text { padding: var(--pt-mb) var(--pr-mb) var(--pb-mb) var(--pl-mb) !important; }
  }
</style>

{% schema %}
{
  "name": "CX Rich Text",
  "settings": [
    { "type": "header", "content": "Box Background" },
    { "type": "image_picker", "id": "bg_img", "label": "Background Image" },
    { "type": "color", "id": "overlay_color", "label": "Overlay Color", "default": "#000000" },
    { "type": "range", "id": "overlay_opacity", "min": 0, "max": 1, "step": 0.1, "label": "Overlay Opacity", "default": 0 },
    { "type": "select", "id": "text_align", "label": "Alignment", "options": [{"value":"left","label":"Left"},{"value":"center","label":"Center"},{"value":"right","label":"Right"}], "default": "center" },
    { "type": "header", "content": "Desktop Padding" },
    { "type": "range", "id": "pd_top_dt", "min": 0, "max": 150, "label": "Top", "default": 40 },
    { "type": "range", "id": "pd_bottom_dt", "min": 0, "max": 150, "label": "Bottom", "default": 40 },
    { "type": "range", "id": "pd_left_dt", "min": 0, "max": 150, "label": "Left", "default": 20 },
    { "type": "range", "id": "pd_right_dt", "min": 0, "max": 150, "label": "Right", "default": 20 },
    { "type": "header", "content": "Mobile Padding" },
    { "type": "range", "id": "pd_top_mb", "min": 0, "max": 100, "label": "Top Mobile", "default": 20 },
    { "type": "range", "id": "pd_bottom_mb", "min": 0, "max": 100, "label": "Bottom Mobile", "default": 20 },
    { "type": "range", "id": "pd_left_mb", "min": 0, "max": 100, "label": "Left Mobile", "default": 15 },
    { "type": "range", "id": "pd_right_mb", "min": 0, "max": 100, "label": "Right Mobile", "default": 15 },
    { "type": "header", "content": "Content" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "CX Rich Text" },
    { "type": "color", "id": "color_h", "label": "Heading Color", "default": "#000" },
    { "type": "number", "id": "fs_h_dt", "label": "Heading Size Desktop", "default": 40 },
    { "type": "richtext", "id": "paragraph", "label": "Paragraph" },
    { "type": "color", "id": "color_p", "label": "Paragraph Color", "default": "#333" }
  ]
}
{% endschema %}